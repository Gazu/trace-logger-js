{
  "name": "@smb-tech/logger-core",
  "version": "1.0.0",
  "description": "Core library for structured logging, events, and serialization",
  "license": "MIT",
  "author": {
    "name": "smb-tech",
    "url": "https://smb-tech.cl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gazu/trace-logger-js.git",
    "directory": "packages/logger-core"
  },
  "bugs": {
    "url": "https://github.com/Gazu/trace-logger-js/issues"
  },
  "keywords": [
    "logging",
    "logger",
    "structured-logging",
    "json-logging",
    "tracing",
    "distributed-tracing",
    "typescript",
    "redaction",
    "pii"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist dist-test",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "pretest": "rm -rf dist-test",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/logger.contract.test.js",
    "prepublishOnly": "npm run test && npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
